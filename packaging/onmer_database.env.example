# OnmerAdminPanel.exe ile ayni klasore "onmer_database.env" adiyla kopyalayin
# (basindaki # yorum satiridir; kopyada kalabilir veya silin)

# PostgreSQL: USE_SQLITE satiri yazmayin (bos birakilirsa eski Windows
# ortam degiskeni USE_SQLITE=1 varsa uygulama onu temizler).
POSTGRES_DB=onmer_yemek
POSTGRES_USER=onmer
POSTGRES_PASSWORD=sifreniz
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Yerel SQLite kullanmak icin asagidakini acin ve PostgreSQL satirlarini kaldirin veya yorum yapin:
# USE_SQLITE=1

# E-posta (Gmail — Google Uygulama Sifresi kullanin, normal sifre degil)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_HOST_USER=sizin@gmail.com
# EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
# DEFAULT_FROM_EMAIL=Onmer Yemek <sizin@gmail.com>
